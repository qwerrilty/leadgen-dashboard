# --- Google Places API (New) ---
# Console: https://console.cloud.google.com/ -> enable "Places API (New)" + billing
GOOGLE_PLACES_API_KEY=

# --- Supabase ---
# Project settings -> API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic ---
ANTHROPIC_API_KEY=

# --- Smartlead (optional, used by /api/queue) ---
SMARTLEAD_API_KEY=
SMARTLEAD_CAMPAIGN_ID=

# --- Sender identity (CAN-SPAM / Spam Act compliance) ---
FROM_NAME="Erril - [Your Business Name]"
FROM_EMAIL=
PHYSICAL_ADDRESS="Required by CAN-SPAM - your business address"
UNSUBSCRIBE_BASE_URL="https://your-app.vercel.app/unsubscribe"

# --- App access ---
# Any string works; this gates the dashboard login (see lib/auth.js)
APP_PASSWORD=

# --- Cron security ---
# Vercel auto-sends this as a Bearer token when it invokes your cron routes.
# Generate any random 16+ char string.
CRON_SECRET=
